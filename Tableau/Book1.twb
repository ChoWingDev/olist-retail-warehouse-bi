      <aliases enabled='yes' />
      <column caption='Order Count' datatype='integer' name='[Calculation_4330725172019200]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([order_id])' />
      </column>
      <column caption='Latest Delivered Week Start' datatype='date' name='[Calculation_4330725218766850]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='{ FIXED : MAX([delivered_week_start]) }' />
      </column>
      <column caption='Is Latest Week' datatype='boolean' name='[Calculation_4330725218951171]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[delivered_week_start]=[Calculation_4330725218766850]' />
      </column>
      <column caption='TY Late Rate' datatype='real' name='[Calculation_4330725223219206]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(IF [Late Rate - Non AGG (copy)_4330725226242058] AND [is_late] THEN [order_id] END)&#10;/&#10;COUNTD(IF [Late Rate - Non AGG (copy)_4330725226242058] THEN [order_id] END)' />
      </column>
      <column caption='Funnel - Delivered' datatype='integer' name='[Calculation_4330725241245714]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(IF [is_delivered] THEN [order_id] END)' />
      </column>
      <column caption='Reviewed Orders' datatype='integer' name='[Calculation_4330725257719843]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(IF NOT ISNULL([review_score]) THEN [order_id] END)' />
      </column>
      <column caption='Low Review Rate' datatype='real' name='[Calculation_4330725257904164]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD( IF [is_low_review] THEN [order_id] END)/[Calculation_4330725257719843]' />
      </column>
      <column caption='Baseline Low Review Rate (bucket=0)' datatype='real' name='[Calculation_4330725258117157]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED :&#10;    COUNTD(IF [delay_bucket]=&apos;0&apos; AND [is_low_review] THEN [order_id] END) / &#10;    COUNTD(IF [delay_bucket]=&apos;0&apos; AND NOT ISNULL([review_score]) THEN [order_id] END)&#10; }' />
      </column>
      <column caption='Lift vs Baseline' datatype='real' name='[Calculation_4330725263147049]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Calculation_4330725257904164]) / WINDOW_MAX(&#10;    IF MIN([delay_bucket]) = &apos;0&apos; THEN ([Calculation_4330725257904164]) END&#10;)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Funnel - Late' datatype='integer' name='[Funnel - Delivered (copy)_4330725241409555]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(IF [is_delivered] AND [is_late] THEN [order_id] END)' />
      </column>
      <column caption='Funnel - Late Reviewed' datatype='integer' name='[Funnel - Delivered (copy)_4330725241819156]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(IF [is_delivered] AND NOT ISNULL([review_score]) AND [is_late] THEN [order_id] END)' />
      </column>
      <column caption='Funnel - Late &amp; Low Review Orders' datatype='integer' name='[Funnel - Late (copy)_4330725241942037]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(IF [is_delivered] AND NOT ISNULL([review_score]) AND [review_score]&lt;=2 AND [is_late] THEN [order_id] END)' />
      </column>
      <column caption='WoW On Time Rate' datatype='real' name='[LY On Time Rate - Non AGG (copy)_4330725229895695]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Late Rate - Non AGG (copy)_4330725224005639]-[TY On Time Rate - Non AGG (copy)_4330725229719566]/[TY On Time Rate - Non AGG (copy)_4330725229719566]' />
      </column>
      <column caption='TY On Time Rate' datatype='real' name='[Late Rate - Non AGG (copy)_4330725224005639]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(IF [Late Rate - Non AGG (copy)_4330725226242058] AND [is_ontime] THEN [order_id] END)&#10;/&#10;COUNTD(IF [Late Rate - Non AGG (copy)_4330725226242058] THEN [order_id] END)' />
      </column>
      <column caption='TY Low Review Rate' datatype='real' name='[Late Rate - Non AGG (copy)_4330725224194056]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(IF [Late Rate - Non AGG (copy)_4330725226242058] AND [is_low_review] THEN [order_id] END)&#10;/&#10;COUNTD(IF [Late Rate - Non AGG (copy)_4330725226242058] THEN [order_id] END)' />
      </column>
      <column caption='This Year' datatype='boolean' name='[Late Rate - Non AGG (copy)_4330725226242058]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[delivered_date]&gt;= [Parameters].[Parameter 1] AND [delivered_date] &lt;=[Parameters].[Start Date (copy)_4330725225193481]' />
      </column>
      <column caption='LY Late Rate' datatype='real' name='[TY Late Rate - Non AGG (copy)_4330725229559820]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(IF [This Year (copy)_4330725226872843] AND [is_late] THEN [order_id] END)&#10;/&#10;COUNTD(IF [This Year (copy)_4330725226872843] THEN [order_id] END)' />
      </column>
      <column caption='LY Low Review Rate' datatype='real' name='[TY Low Review Rate - Non AGG (copy)_4330725229637645]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(IF [This Year (copy)_4330725226872843] AND [is_low_review] THEN [order_id] END)&#10;/&#10;COUNTD(IF [This Year (copy)_4330725226872843] THEN [order_id] END)' />
      </column>
      <column caption='LY On Time Rate' datatype='real' name='[TY On Time Rate - Non AGG (copy)_4330725229719566]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(IF [This Year (copy)_4330725226872843] AND [is_ontime] THEN [order_id] END)&#10;/&#10;COUNTD(IF [This Year (copy)_4330725226872843] THEN [order_id] END)' />
      </column>
      <column caption='Last Year' datatype='boolean' name='[This Year (copy)_4330725226872843]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[delivered_date]&gt;= DATEADD(&apos;year&apos;, -1,[Parameters].[Parameter 1] ) AND [delivered_date] &lt;= DATEADD(&apos;year&apos;, -1, [Parameters].[Start Date (copy)_4330725225193481])' />
      </column>
      <column caption='WoW Low Review Rate' datatype='real' name='[WoW On Time Rate (copy)_4330725231796241]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Late Rate - Non AGG (copy)_4330725224194056]-[TY Low Review Rate - Non AGG (copy)_4330725229637645]/[TY Low Review Rate - Non AGG (copy)_4330725229637645]' />
      </column>
      <column caption='WoW Late Rate ' datatype='real' name='[WoW On Time Rate - Non AGG (copy)_4330725231210512]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_4330725223219206]-[TY Late Rate - Non AGG (copy)_4330725229559820]/[TY Late Rate - Non AGG (copy)_4330725229559820]' />
      </column>
